@model IEnumerable<Department>

<h2>Departments</h2>

<a href="/Department/Create">Add Department</a>

<table class="table">
    <tr>
        <th>Name</th>
        <th>Description</th>
        <th>Active</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Description</td>
            <td>@item.IsActive</td>
            <td>
            <button class="btn btn-warning" onclick="editDept(@item.Id)">Edit</button>
            <a href="/Department/Delete/@item.Id" class="btn btn-danger">Delete</a>
                <a href="/Department/Edit/@item.Id" class="btn btn-warning">Edit</a>
            </td>
        </tr>
    }
</table>